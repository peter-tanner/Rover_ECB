{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {
                "CMSIS_Dvendor": "STMicroelectronics:13",
                "CMSIS_Dname": "STM32F103RCT7",
                "CMSIS_Dcore": "Cortex-M3",
                "CMSIS_Dtz": "NO_TZ",
                "CMSIS_Dfpu": "NO_FPU",
                "CMSIS_Ddsp": "NO_DSP",
                "CMSIS_Dmve": "NO_MVE",
                "CMSIS_Dmpu": "MPU",
                "CMSIS_Dendian": "Little-endian",
                "CMSIS_Dsecure": "",
                "CMSIS_Tcompiler": "GCC"
            }
        },
        {
            "name": "Debug",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CUBE_CMAKE_C_FLAGS": "-mfloat-abi=soft;-mthumb;--specs=nano.specs;-mcpu=cortex-m3;-std=gnu11;-g3;-DDEBUG;-DUSE_HAL_DRIVER;-DSTM32F103xE;-O0;-ffunction-sections;-fdata-sections;-Wall;-fstack-usage;-fcyclomatic-complexity",
                "CUBE_CMAKE_CXX_FLAGS": "-mfloat-abi=soft;-mthumb;--specs=nano.specs;-mcpu=cortex-m3;-std=gnu++14;-g3;-O0;-ffunction-sections;-fdata-sections;-fno-exceptions;-fno-rtti;-fno-use-cxa-atexit;-Wall;-fstack-usage;-fcyclomatic-complexity",
                "CUBE_CMAKE_ASM_FLAGS": "-mfloat-abi=soft;-mthumb;--specs=nano.specs;-mcpu=cortex-m3;-g3;-DDEBUG;-x;assembler-with-cpp",
                "CUBE_CMAKE_EXE_LINKER_FLAGS": "-mfloat-abi=soft;-mthumb;--specs=nano.specs;-mcpu=cortex-m3;-TSTM32F103RCTX_FLASH.ld;--specs=nosys.specs;-Wl,-Map=Rover_ECB.map\";-Wl,--gc-sections;-static"
            }
        },
        {
            "name": "Release",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CUBE_CMAKE_C_FLAGS": "-mfloat-abi=soft;-mthumb;--specs=nano.specs;-mcpu=cortex-m3;-std=gnu11;-DUSE_HAL_DRIVER;-DSTM32F103xE;-Os;-ffunction-sections;-fdata-sections;-Wall;-fstack-usage;-fcyclomatic-complexity",
                "CUBE_CMAKE_CXX_FLAGS": "-mfloat-abi=soft;-mthumb;--specs=nano.specs;-mcpu=cortex-m3;-std=gnu++14;-Os;-ffunction-sections;-fdata-sections;-fno-exceptions;-fno-rtti;-fno-use-cxa-atexit;-Wall;-fstack-usage;-fcyclomatic-complexity",
                "CUBE_CMAKE_ASM_FLAGS": "-mfloat-abi=soft;-mthumb;--specs=nano.specs;-mcpu=cortex-m3;-x;assembler-with-cpp",
                "CUBE_CMAKE_EXE_LINKER_FLAGS": "-mfloat-abi=soft;-mthumb;--specs=nano.specs;-mcpu=cortex-m3;-TSTM32F103RCTX_FLASH.ld;--specs=nosys.specs;-Wl,-Map=Rover_ECB.map\";-Wl,--gc-sections;-static"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug",
            "configurePreset": "Debug"
        },
        {
            "name": "Release",
            "configurePreset": "Release"
        }
    ]
}